{
  "name": "com.blenminer.nowui",
  "version": "0.1.0",
  "displayName": "NowUI",
  "description": "Immediate-mode UI renderer for Unity: batched rectangles, MSDF text, flexbox-style layout, pointer/touch/gamepad input, themes, and Lottie vector animation. Renders through the built-in pipeline, URP, HDRP, or a UGUI CanvasRenderer.",
  "unity": "6000.4",
  "documentationUrl": "https://github.com/BlenMiner/NowUI/tree/main/Docs",
  "changelogUrl": "https://github.com/BlenMiner/NowUI/blob/main/Assets/NowUI/CHANGELOG.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlenMiner/NowUI.git"
  },
  "dependencies": {
    "com.unity.burst": "1.8.27",
    "com.unity.collections": "2.6.5",
    "com.unity.inputsystem": "1.19.0",
    "com.unity.mathematics": "1.3.2",
    "com.unity.ugui": "2.0.0",
    "com.unity.modules.unitywebrequest": "1.0.0",
    "com.unity.modules.uielements": "1.0.0"
  },
  "keywords": [
    "ui",
    "immediate-mode",
    "msdf",
    "sdf",
    "text",
    "layout",
    "lottie",
    "vector-graphics",
    "docking",
    "node-graph"
  ],
  "samples": [
    {
      "displayName": "Quick Start",
      "description": "Small built-in and RenderTexture examples, including explicit warmup and glass diagnostics storage.",
      "path": "Samples~/QuickStart"
    }
  ],
  "author": {
    "name": "BlenMiner",
    "url": "https://github.com/BlenMiner"
  }
}
